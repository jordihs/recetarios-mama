{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Esquema de Recetario v2",
  "description": "Versión 2 del esquema. Introduce el array CONTENIDO en TipoIntroduccion para preservar el orden original de títulos, párrafos, imágenes y tablas tal como aparecen en el documento fuente.",
  "type": "object",
  "required": ["RECETARIO"],
  "properties": {
    "RECETARIO": {
      "type": "object",
      "required": ["TITULO", "CAPITULO"],
      "properties": {
        "TITULO": { "type": "string" },
        "INTRODUCCION": { "$ref": "#/definitions/TipoIntroduccion" },
        "CAPITULO": {
          "type": "array",
          "items": { "$ref": "#/definitions/TipoCapitulo" }
        }
      }
    }
  },
  "definitions": {
    "TipoIntroduccion": {
      "type": "object",
      "description": "Bloque introductorio de un capítulo o del recetario. El campo CONTENIDO preserva el orden original de los elementos (títulos, párrafos, imágenes sueltas, galerías de imágenes y tablas). Las imágenes de cabecera que preceden a todo el texto se pueden incluir también en CONTENIDO con tipo 'IMAGEN' o 'IMAGENES'.",
      "properties": {
        "CONTENIDO": {
          "type": "array",
          "description": "Secuencia ordenada de bloques de contenido tal como aparecen en el documento original.",
          "items": { "$ref": "#/definitions/TipoBloque" }
        }
      }
    },
    "TipoBloque": {
      "description": "Un bloque de contenido dentro de una introducción. El campo 'tipo' discrimina el tipo de bloque.",
      "oneOf": [
        { "$ref": "#/definitions/TipoBloqueImagen" },
        { "$ref": "#/definitions/TipoBloqueImagenes" },
        { "$ref": "#/definitions/TipoBloqueTabla" },
        { "$ref": "#/definitions/TipoBloqueParrafo" },
        { "$ref": "#/definitions/TipoBloqueTitulo" },
        { "$ref": "#/definitions/TipoBloqueNota" }
      ]
    },
    "TipoBloqueNota": {
      "type": "object",
      "required": ["tipo", "texto"],
      "additionalProperties": false,
      "properties": {
        "tipo": { "type": "string", "enum": ["NOTA"] },
        "texto": { "type": "string" }
      }
    },
    "TipoBloqueTitulo": {
      "type": "object",
      "required": ["tipo", "texto"],
      "additionalProperties": false,
      "properties": {
        "tipo": { "type": "string", "enum": ["TITULO"] },
        "texto": { "type": "string" }
      }
    },
    "TipoBloqueParrafo": {
      "type": "object",
      "required": ["tipo", "texto"],
      "additionalProperties": false,
      "properties": {
        "tipo": { "type": "string", "enum": ["PARRAFO"] },
        "texto": { "type": "string" }
      }
    },
    "TipoBloqueImagen": {
      "type": "object",
      "required": ["tipo", "imagen"],
      "additionalProperties": false,
      "properties": {
        "tipo": { "type": "string", "enum": ["IMAGEN"] },
        "imagen": { "$ref": "#/definitions/TipoImagen" }
      }
    },
    "TipoBloqueImagenes": {
      "type": "object",
      "required": ["tipo", "imagenes"],
      "additionalProperties": false,
      "properties": {
        "tipo": { "type": "string", "enum": ["IMAGENES"] },
        "imagenes": {
          "type": "array",
          "items": { "$ref": "#/definitions/TipoImagen" }
        }
      }
    },
    "TipoBloqueTabla": {
      "type": "object",
      "required": ["tipo", "tabla"],
      "additionalProperties": false,
      "properties": {
        "tipo": { "type": "string", "enum": ["TABLA"] },
        "tabla": { "$ref": "#/definitions/TipoTabla" }
      }
    },
    "TipoTabla": {
      "type": "object",
      "required": ["FILA"],
      "properties": {
        "@attributes": {
          "type": "object",
          "properties": {
            "titulo": { "type": "string" }
          }
        },
        "CABECERA": { "$ref": "#/definitions/TipoFilaCelda" },
        "FILA": {
          "oneOf": [
            { "$ref": "#/definitions/TipoFilaCelda" },
            { "type": "array", "items": { "$ref": "#/definitions/TipoFilaCelda" } }
          ]
        }
      }
    },
    "TipoFilaCelda": {
      "type": "object",
      "required": ["CELDA"],
      "properties": {
        "CELDA": {
          "type": "array",
          "items": { "$ref": "#/definitions/TipoCelda" }
        }
      }
    },
    "TipoCelda": {
      "type": "object",
      "properties": {
        "@attributes": {
          "type": "object",
          "properties": {
            "imagen": { "type": "string" }
          }
        },
        "#text": { "type": "string" }
      }
    },
    "TipoCapitulo": {
      "type": "object",
      "required": ["@attributes"],
      "properties": {
        "@attributes": {
          "type": "object",
          "required": ["nombre"],
          "properties": {
            "nombre": { "type": "string" }
          }
        },
        "INTRODUCCION": { "$ref": "#/definitions/TipoIntroduccion" },
        "CAPITULO": {
          "oneOf": [
            { "$ref": "#/definitions/TipoCapitulo" },
            { "type": "array", "items": { "$ref": "#/definitions/TipoCapitulo" } }
          ]
        },
        "RECETA": {
          "oneOf": [
            { "$ref": "#/definitions/TipoReceta" },
            { "type": "array", "items": { "$ref": "#/definitions/TipoReceta" } }
          ]
        }
      }
    },
    "TipoReceta": {
      "type": "object",
      "required": ["TITULO"],
      "description": "INGREDIENTES y PREPARACION son opcionales porque el corpus original contiene recetas incompletas que carecen de ellos.",
      "properties": {
        "@attributes": {
          "type": "object",
          "properties": {
            "imagen": { "type": "string" }
          }
        },
        "TITULO": { "type": "string" },
        "INGREDIENTES": {
          "type": "object",
          "required": ["GRUPO"],
          "properties": {
            "@attributes": {
              "type": "object",
              "properties": {
                "personas": { "type": "string" }
              }
            },
            "GRUPO": {
              "oneOf": [
                { "$ref": "#/definitions/TipoGrupoIngredientes" },
                { "type": "array", "items": { "$ref": "#/definitions/TipoGrupoIngredientes" } }
              ]
            }
          }
        },
        "PREPARACION": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "NOTA": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        }
      }
    },
    "TipoGrupoIngredientes": {
      "type": "object",
      "required": ["INGREDIENTE"],
      "properties": {
        "@attributes": {
          "type": "object",
          "properties": {
            "titulo": { "type": "string" }
          }
        },
        "INGREDIENTE": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        }
      }
    },
    "TipoImagen": {
      "type": "object",
      "required": ["@attributes"],
      "properties": {
        "@attributes": {
          "type": "object",
          "required": ["src"],
          "properties": {
            "src": { "type": "string" }
          }
        },
        "#text": { "type": "string" }
      }
    }
  }
}
